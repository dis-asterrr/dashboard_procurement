DATABASE_URL=

# Use these DB_* values when DATABASE_URL is not set.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_me
DB_NAME=rygell_dashboard
DB_SSLMODE=disable

# Database log level: silent, error, warn, info (default: warn)
DB_LOG_LEVEL=warn

# Railway usually injects PORT automatically.
PORT=8080
SERVER_PORT=8080

UPLOAD_DIR=./uploads
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:3001

# JWT_SECRET must be at least 32 characters and not a default/placeholder value.
JWT_SECRET=change_me_to_a_strong_random_secret_at_least_32_chars
JWT_EXPIRY_HOURS=24
COOKIE_NAME=auth_token
COOKIE_DOMAIN=
COOKIE_SAMESITE=Lax
COOKIE_SECURE=false

ADMIN_NAME=Administrator
ADMIN_USERNAME=admin
# ADMIN_PASSWORD must be a strong non-default value.
ADMIN_PASSWORD=change_me
ADMIN_SYNC_PASSWORD=false

# Whether to keep uploaded import files after confirmation (default: false).
# Set to true to retain files for debugging/audit purposes.
IMPORT_KEEP_FILES=false
